{
  "name": "scry",
  "version": "1.0.0",
  "description": "Automated website quality auditing platform",
  "scripts": {
    "test": "node run-tests.js",
    "install-browsers": "node scripts/maintenance/install-browsers.js",
    "setup": "npm run install-browsers && npm run styles:build",
    "baselines:update": "node scripts/discovery/update-baselines.js",
    "discover": "node scripts/discovery/discover-pages.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prettier:check": "prettier --check \"*.js\" \"*.json\" \"scripts/**/*.js\" \"utils/**/*.js\"",
    "prettier:write": "prettier --write \"*.js\" \"*.json\" \"scripts/**/*.js\" \"utils/**/*.js\"",
    "gate:ci": "npm run lint && npm run test:unit && npm run prettier:check && npm run app:lint && npm run app:check && npm run app:build && npm run app:test",
    "lint:teardown": "node scripts/maintenance/check-browser-teardown.js",
    "test:unit": "node --test tests/unit/**/*.test.js",
    "reports:read": "node scripts/reporting/read-reports.js",
    "reports:regenerate": "node scripts/reporting/regenerate-report.js",
    "reports:dev": "node scripts/reporting/serve-report-dev.js --open",
    "test:visual": "node run-tests.js --visual",
    "test:responsive": "node run-tests.js --responsive",
    "test:functionality": "node run-tests.js --functionality",
    "test:accessibility": "node run-tests.js --accessibility",
    "clean:reports": "node scripts/maintenance/cleanup.js clean-reports",
    "clean:manifests": "node scripts/maintenance/cleanup.js clean-manifests",
    "clean:test-results": "node scripts/maintenance/cleanup.js clean-test-results",
    "styles:build": "node scripts/reporting/build-report-styles.js",
    "site:build": "node site/build.js",
    "site:dev": "node site/serve.js --open",
    "app:build": "npm --prefix app run build",
    "app:check": "npm --prefix app run check",
    "app:dev": "npm --prefix app run dev",
    "app:lint": "npm --prefix app run lint",
    "app:preview": "npm --prefix app run preview",
    "app:test": "npm --prefix app run test --if-present",
    "app:mock:build": "npx @tailwindcss/cli -i site/app/styles/input.css -o site/app/styles/app.css",
    "app:mock:dev": "npx @tailwindcss/cli -i site/app/styles/input.css -o site/app/styles/app.css --watch & npx serve site/app -l 4401 --no-clipboard",
    "app:mock:serve": "npx serve site/app -l 4401 --no-clipboard"
  },
  "lint-staged": {},
  "keywords": [
    "testing",
    "wordpress",
    "playwright",
    "automation",
    "accessibility"
  ],
  "author": "Scry",
  "license": "MIT",
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/cli": "^4.2.2",
    "chokidar": "^4.0.3",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "pixelmatch": "^5.3.0",
    "pngjs": "^7.0.0",
    "prettier": "^3.8.1",
    "serve": "^14.2.6",
    "tailwindcss": "^4.2.2"
  },
  "dependencies": {
    "minimist": "^1.2.8",
    "open": "^10.2.0",
    "sass": "^1.98.0"
  },
  "overrides": {
    "flatted": "^3.4.1"
  }
}
